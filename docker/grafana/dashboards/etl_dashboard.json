{
  "title": "ETL Ultimate Visibility",
  "uid": "etl-ultimate-visibility",
  "panels": [
    {
      "type": "timeseries",
      "title": "Goroutines",
      "targets": [
        {
          "expr": "etl_goroutines",
          "refId": "A",
          "datasource": {"uid": "Prometheus"}
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "Memory Usage (MB)",
      "targets": [
        {
          "expr": "etl_memory_alloc_mb",
          "legendFormat": "Allocated",
          "refId": "A",
          "datasource": {"uid": "Prometheus"}
        },
        {
          "expr": "etl_memory_sys_mb",
          "legendFormat": "System",
          "refId": "B",
          "datasource": {"uid": "Prometheus"}
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "Request Count",
      "targets": [
        {
          "expr": "rate(etl_request_count[1m])",
          "legendFormat": "{{level}}",
          "refId": "A",
          "datasource": {"uid": "Prometheus"}
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
    },
    {
      "type": "logs",
      "title": "Application Logs",
      "targets": [
        {
          "expr": "{source=\"app_logs\"}",
          "refId": "A",
          "datasource": {"uid": "Loki"}
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
    }
  ],
  "schemaVersion": 38
}

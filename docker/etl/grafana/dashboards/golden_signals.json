{
  "title": "Four Golden Signals",
  "uid": "golden-signals",
  "panels": [
    {
      "title": "Latency (GC Pause)",
      "type": "timeseries",
      "datasource": { "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(etl_gc_pause_ms_sum[1m])) / sum(rate(etl_gc_pause_ms_count[1m]))",
          "legendFormat": "Average GC Pause (ms)"
        }
      ]
    },
    {
      "title": "Traffic (Request Count)",
      "type": "timeseries",
      "datasource": { "uid": "Prometheus" },
      "targets": [
        {
          "expr": "rate(etl_request_count[1m])",
          "legendFormat": "Requests / sec"
        }
      ]
    },
    {
      "title": "Errors (Error Logs)",
      "type": "logs",
      "datasource": { "uid": "Loki" },
      "targets": [
        {
          "expr": "{source=\"vector\"} |= \"error\""
        }
      ]
    },
    {
      "title": "Saturation (Goroutines)",
      "type": "timeseries",
      "datasource": { "uid": "Prometheus" },
      "targets": [
        {
          "expr": "etl_goroutines",
          "legendFormat": "Goroutines"
        }
      ]
    }
  ],
  "schemaVersion": 36
}

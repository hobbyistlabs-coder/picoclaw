{
  "title": "System Overview",
  "uid": "system-overview",
  "panels": [
    {
      "type": "timeseries",
      "title": "Traffic (RPS)",
      "targets": [
        {
          "expr": "rate(etl_http_requests_total[1m])",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Latency (p95 ms)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(etl_http_request_duration_seconds_bucket[5m])) * 1000",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Errors (Rate)",
      "targets": [
        {
          "expr": "rate(etl_http_requests_total{status=~\"5..\"}[1m])",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "type": "timeseries",
      "title": "Saturation (CPU Usage / Goroutines)",
      "targets": [
        {
          "expr": "etl_goroutines",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    },
    {
      "type": "timeseries",
      "title": "Memory Allocation (MB)",
      "targets": [
        {
          "expr": "etl_memory_alloc_mb",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
    },
    {
      "type": "timeseries",
      "title": "GC Pause Time (ms)",
      "targets": [
        {
          "expr": "etl_gc_pause_ms",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
    }
  ],
  "schemaVersion": 38,
  "timezone": "browser"
}